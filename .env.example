# ---------------------------------------------------------
# DorkHunter -- Environment Configuration
# ---------------------------------------------------------
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------

# Serper.dev API keys (comma-separated for auto-rotation)
# Leave empty if using Free Search mode (option 2 in menu)
# SERPER_API_KEYS=key1,key2,key3

# How many result pages to fetch per dork query
# SERPER_PAGES_PER_QUERY=1

# Results per page (max 100 for Serper.dev)
# SERPER_RESULTS_PER_QUERY=100

# Concurrent Serper API calls
# SERPER_SEARCH_CONCURRENCY=10

# Path to dorks file (one dork query per line)
QUERIES_FILE=dorks.txt

# Search settings
# SEARCH_TIMEOUT_MS=15000
# SEARCH_MAX_THREADS=10

# Free search engines to use (comma-separated)
# Options: duckduckgo, bing, yahoo, google, ask
# FREE_SEARCH_ENGINES=duckduckgo,bing

# Optional: rotating proxy URL (SOCKS5 or HTTP)
# PROXY_URL=socks5://user:pass@proxy-host:1080
