# ---------------------------------------------------------
# MM2 Shop Discovery Tool -- Environment Configuration
# ---------------------------------------------------------
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------

# Serper.dev API keys (comma-separated for auto-rotation)
SERPER_API_KEYS=key1,key2,key3

# How many result pages to scrape per query (20+ for maximum coverage)
# SERPER_PAGES_PER_QUERY=20

# Results per page (max 100)
# SERPER_RESULTS_PER_QUERY=100

# Concurrent Serper API calls (all queries x pages run in parallel)
# SERPER_SEARCH_CONCURRENCY=10

# Optional: path to a TXT file with custom search queries (one per line).
# QUERIES_FILE=queries.txt

# Scraper settings
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=12000

# Fast scan: max concurrent HTTP connections (500+ for max throughput)
SCRAPER_MAX_CONCURRENCY=500

# Deep scan (Playwright): concurrent browser tabs for passed URLs
SCRAPER_DEEP_SCAN_CONCURRENCY=5

# Enable/disable deep Playwright scan for URLs that pass fast scan
# ENABLE_DEEP_SCAN=true

# Optional: rotating proxy URL (SOCKS5 or HTTP)
# PROXY_URL=socks5://user:pass@proxy-host:1080

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
